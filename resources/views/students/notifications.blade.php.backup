    @push('scripts')
    <script>
        $(document).ready(function() {
            // Mark single notification as read
            $('.mark-read-btn').on('click', function() {
                const id = $(this).data('id');
                const item = $(this).closest('.list-group-item');
                
                $.post(`/notifications/${id}/mark-read`, {
                    _token: '{{ csrf_token() }}'
                })
                .done(function(response) {
                    if (response.success) {
                        item.removeClass('bg-light');
                        item.find('.fw-bold').removeClass('fw-bold');
                        item.find('.mark-read-btn').remove();
                        item.find('.rounded-circle').css('background-color', '#e9ecef');
                        updateNotificationCount();
                    }
                });
            });

            // Mark all notifications as read
            $('#markAllRead').on('click', function() {
                $.post('/notifications/mark-all-read', {
                    _token: '{{ csrf_token() }}'
                })
                .done(function(response) {
                    if (response.success) {
                        $('.list-group-item').removeClass('bg-light');
                        $('.fw-bold').removeClass('fw-bold');
                        $('.mark-read-btn').remove();
                        $('.rounded-circle').css('background-color', '#e9ecef');
                        updateNotificationCount();
                    }
                });
            });

            function updateNotificationCount() {
                $.get('/notifications/unread-count')
                .done(function(response) {
                    const badge = $('#notification-badge');
                    if (response.count > 0) {
                        badge.text(response.count).show();
                    } else {
                        badge.hide();
                    }
                });
            }
        });
    </script>
    @endpush
